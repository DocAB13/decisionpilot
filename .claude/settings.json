{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -File .claude/hook-notify.ps1",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
